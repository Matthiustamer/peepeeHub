-- MAIN TAB --
local MainTab = Window:CreateTab("Main🏠", nil) -- Title, Image
local MainSection = MainTab:CreateSection("Useful Tools")

local fishing = false -- Tracks whether the loop should keep running

local Toggle = MainTab:CreateToggle({
    Name = "Enable AutoCatchFish",
    CurrentValue = false,
    Flag = "Toggle1", 
    Callback = function(Value)
        fishing = Value -- Update our tracking variable (true or false)

        if fishing then
            Rayfield:Notify({
                Title = "AutoCatch",
                Content = "Toggled on!",
                Duration = 2.5,
                Image = 4483362458,
            })
            
            -- task.spawn prevents the infinite loop from crashing your UI
            task.spawn(function()
                while true do
                    -- 1. Check if the toggle was turned off
                    if not fishing then 
                        break -- This exits the 'while true do' loop completely
                    end
                    
                    -- 2. Your script logic
                    game:GetService("ReplicatedStorage"):WaitForChild("Events"):WaitForChild("Fish"):WaitForChild("ReelSessionHit"):FireServer()
                    task.wait(0.001)
                    print("debug")
                end
            end)
        else
            Rayfield:Notify({
                Title = "AutoCatch",
                Content = "Toggled off!",
                Duration = 2.5,
                Image = 4483362458,
            })
        end
    end,
})



